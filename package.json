{
  "name": "morpho-dapp",
  "description": "Abstraction layer for Morpho's complexity.",
  "version": "0.0.1",
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Foulks-Plb <https://x.com/FoulkPlb>"
  ],
  "repository": "github:morpho-org/morpho-dapp",
  "homepage": "https://github.com/morpho-org/morpho-dapp",
  "bugs": {
    "url": "https://github.com/morpho-org/morpho-dapp/issues",
    "email": "contact@morpho.org"
  },
  "license": "MIT",
  "main": "src/index.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "prepublish": "$npm_execpath build",
    "lint": "biome check",
    "build": "tsc --noEmit && tsc --build tsconfig.build.json",
    "link": "pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build:link": "pnpm run build && pnpm link --global",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@morpho-org/test": "2.6.1-next.1",
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "dotenv": "^17.2.3",
    "typescript": "^5.7.2",
    "viem": "^2.28.0",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "main": "lib/index.js",
    "types": "lib/index.d.ts"
  },
  "dependencies": {
    "@morpho-org/blue-sdk": "5.3.0-next.2",
    "@morpho-org/blue-sdk-viem": "4.1.0-next.5",
    "@morpho-org/bundler-sdk-viem": "4.1.0-next.1",
    "@morpho-org/morpho-ts": "^2.4.3",
    "@morpho-org/simulation-sdk": "3.2.0-next.4"
  }
}
