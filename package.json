{
  "name": "@morpho-org/consumer-sdk",
  "description": "Abstraction layer for Morpho's complexity.",
  "version": "0.1.1",
  "author": "Morpho Association <contact@morpho.org>",
  "contributors": [
    "Foulks-Plb <https://x.com/FoulkPlb>"
  ],
  "repository": "github:morpho-org/consumer-sdk",
  "homepage": "https://github.com/morpho-org/consumer-sdk",
  "bugs": {
    "url": "https://github.com/morpho-org/consumer-sdk/issues",
    "email": "contact@morpho.org"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "main": "src/index.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "prepublish": "$npm_execpath build",
    "lint": "biome check",
    "prepare": "husky install",
    "build": "tsc --noEmit && tsc --build tsconfig.build.json",
    "link": "pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build:link": "pnpm run build && pnpm link --global",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@changesets/cli": "^2.29.8",
    "@morpho-org/test": "2.6.5",
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "typescript": "^5.7.2",
    "viem": "^2.41.2",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "lib/index.d.ts"
  },
  "dependencies": {
    "@morpho-org/blue-sdk": "^5.9.1",
    "@morpho-org/blue-sdk-viem": "^4.1.4",
